# ── Cloud / Dokploy configuration ───────────────────
DOMAIN_HOST=
APP_IMAGE_TAG=cloud
DATABASE_URL=
SECRET_KEY=supersecretkey
PRISMA_SCHEMA_DEPLOY=true
PRISMA_SCHEMA_DEPLOY_STRATEGY=push

# ── Dev Database Configuration ────────────────────
PG_USER=postgres
PG_PASS=postgres
PG_DB=postgres
SECRET_KEY=supersecretkey

# ── Logging ──────────────────────────────────────────
# Supported levels: debug, info, warn, error.
LOG_LEVEL=info
# Set to true only when diagnosing frontend HTTP requests.
HTTP_ACCESS_LOGS=false
# Set to true only when diagnosing API HTTP requests.
API_ACCESS_LOGS=false
# This project currently has no dedicated worker; keep false unless a future worker needs DB startup gating.
WORKER_WAIT_FOR_DB=false

# ── Redis (Optional) ───────────────────────────────────
REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_PASSWORD=
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
REDIS_KEY_PREFIX=
REDIS_DEFAULT_TTL=300
REDIS_CONNECT_TIMEOUT=5
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=3
REDIS_MAX_RETRIES=3

# ── Migration Failure (Emergency Only) ─────────────
# Set to true only if you need to start the container despite failed migrations.
# Never enable this in production without manual verification.
ALLOW_MIGRATION_FAILURE=false

# =============================================================================
# discord-enterprise-bot
# =============================================================================
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_UPDATES_CHANNEL_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_WELCOME_CHANNEL_ID=
DISCORD_WELCOME_DM_ENABLED=true
DISCORD_COMMAND_SCOPE=global
DISCORD_ANNOUNCE_DEPLOYMENTS=true
APP_VERSION=1.1.0
GIT_COMMIT_SHA=
BUILD_DATE=
NODE_ENV=production
