# =============================================================================
# Global runtime
# =============================================================================

NODE_ENV=development
ENVIRONMENT=development

# =============================================================================
# discord-enterprise
# Embedded PostgreSQL + API + Next.js
# =============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=aether
DB_NAME=etheria_account
DB_PASSWORD=change-me
DATABASE_URL=postgresql://aether:change-me@localhost:5432/etheria_account

USE_EMBEDDED_DB=true
SERVER_PORT=8080
GIN_MODE=debug
JWT_SECRET=change-me-in-production
CORS_ALLOWED_ORIGINS=*

NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development

# =============================================================================
# discord-enterprise-bot
# Defaults target the discord-enterprise container on the Docker network
# =============================================================================

BOT_DB_HOST=discord-enterprise
BOT_DB_PORT=5432
BOT_DB_USER=aether
BOT_DB_NAME=etheria_account
BOT_DB_PASSWORD=change-me

API_INTERNAL_URL=http://discord-enterprise:8080
ADMIN_SECRET=change-me

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# =============================================================================
# Optional frontend/public env
# =============================================================================

NEXT_PUBLIC_CLIENT_ID=
NEXT_PUBLIC_IDENTITY_API_URL=
NEXT_PUBLIC_NAVIGATION_MODE=development
NEXT_PUBLIC_LICENSE_TYPE=
NEXT_PUBLIC_LICENSE_KEY=
NEXT_PUBLIC_LICENSE_EXPIRATION=

BASE_PATH=
ASSET_PREFIX=
DOCS_DEV=false
CAPACITOR=false
LOG_LEVEL=info
